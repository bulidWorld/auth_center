# Server
PORT=10531
NODE_ENV=production

# LDAP
LDAP_URL=ldap://192.168.124.247:389
LDAP_BIND_DN=cn=admin,dc=naze
LDAP_BIND_PASSWORD=Naze666666
LDAP_BASE_DN=dc=naze
LDAP_USER_SEARCH_BASE=dc=naze
LDAP_USER_SEARCH_FILTER=(uid={{username}})

# JWT
JWT_KEY_DIR=./data
JWT_ISSUER=http://localhost:10531
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=604800

# Session
SESSION_SECRET=replace-with-a-random-64-character-string-here
SESSION_COOKIE_NAME=ac_session
SESSION_TTL=86400

# Auth Code TTL (seconds)
AUTH_CODE_TTL=60

# Database
DB_PATH=./data/auth_center.db

# Admin API Key
ADMIN_API_KEY=replace-with-a-random-admin-api-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:10531,http://localhost:3001
